---
// src/pages/explore/[word].astro
import Nav from '../../components/Nav.astro';
import WordPanel from '../../components/WordPanel.tsx';
import EtymologyTree from '../../components/EtymologyTree.tsx';
import { fetchWordData } from '../../lib/etymology';
import '../../styles/global.css';

export const prerender = false;

const { word } = Astro.params;
const data = await fetchWordData(word!);

if (!data) {
  return Astro.redirect('/404');
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{data.word} · Rootword Explorer</title>
  <meta name="description" content={`Etymology of "${data.word}": ${data.definition.replace(/<[^>]*>/g, '').slice(0, 150)}`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="bg-[#0C0B09] text-[#F0E6CC] h-screen flex flex-col overflow-hidden">

  <Nav />

  <main class="flex flex-1 overflow-hidden">

    <!-- Sidebar Panel -->
    <WordPanel data={data} client:load />

    <!-- Tree Canvas -->
    <div class="flex-1 flex flex-col border-l border-[#1E1B14] bg-[#0C0B09] overflow-hidden">

      <!-- Tab bar -->
      <div class="h-11 border-b border-[#1E1B14] flex items-center px-4 gap-2 bg-[#0E0D0B]/80 backdrop-blur shrink-0">
        <button class="text-[11px] font-mono text-[#D4A843] border border-[#3A3525] rounded-md px-3 py-1 bg-[#1A1710]">
          tree view
        </button>
        <button
          onclick="alert('Timeline View — coming in v2.0! Nodes arranged on a linear century axis.')"
          class="text-[11px] font-mono text-[#5A5438] border border-[#1E1B14] rounded-md px-3 py-1 bg-[#0E0D0B] hover:text-[#C4AD82] hover:border-[#3A3525] transition-all duration-200 cursor-pointer"
        >
          timeline
        </button>
        <button
          onclick="alert('World Map View — coming in v2.0! Roots plotted on an interactive historical map.')"
          class="text-[11px] font-mono text-[#5A5438] border border-[#1E1B14] rounded-md px-3 py-1 bg-[#0E0D0B] hover:text-[#C4AD82] hover:border-[#3A3525] transition-all duration-200 cursor-pointer"
        >
          world map
        </button>

        <span class="flex-1" />
        <span class="text-[10px] font-mono text-[#3A3525] hidden sm:inline select-none">click any node to inspect</span>
      </div>

      <!-- Tree Area -->
      <div class="flex-1 overflow-auto p-6 relative" style="min-height: 0;">
        <EtymologyTree data={data} client:load />
      </div>

    </div>
  </main>

</body>
</html>
