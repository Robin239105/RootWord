---
// src/pages/404.astro
import Nav from '../components/Nav.astro';
import SearchBar from '../components/SearchBar.tsx';
import '../styles/global.css';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Etymology Lost · Rootword</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen flex flex-col bg-grid">

  <Nav />

  <main class="flex-1 flex flex-col items-center justify-center px-6 py-16 text-center">

    <div class="max-w-md w-full animate-fade-in-up">

      <!-- Symbol -->
      <div class="mb-8 select-none">
        <div class="text-8xl font-serif text-[#D4A843] mb-4 leading-none"
          style="text-shadow: 0 0 40px rgba(212,168,67,0.5), 0 0 80px rgba(212,168,67,0.2);">
          ✶
        </div>
        <h1 class="text-4xl font-serif font-semibold text-[#F0E6CC] mb-3">
          Etymology Unattested
        </h1>
        <p class="text-sm font-mono text-[#D4A843] tracking-widest uppercase">
          Lost to prehistoric times · 404
        </p>
      </div>

      <!-- Flavor text -->
      <div class="bg-[#161410] border border-[#2E2A1C] rounded-xl p-6 mb-8">
        <p class="text-sm font-serif italic text-[#C4AD82] leading-relaxed">
          &ldquo;This word has left no written tracks in our database or online records,
          or the scriptorium has not yet transcribed its ancient lineage.&rdquo;
        </p>
      </div>

      <!-- Actions -->
      <div class="flex flex-col items-center gap-4">
        <SearchBar client:load placeholder="search another word…" />

        <a
          href="/"
          class="text-sm font-mono text-[#C4AD82] hover:text-[#F0E6CC] border border-[#2E2A1C] hover:border-[#D4A843]/60 rounded-xl px-6 py-3 bg-[#161410] hover:bg-[#1A1710] transition-all duration-200"
        >
          ← return to scriptorium
        </a>
      </div>
    </div>
  </main>

  <footer class="border-t border-[#1E1B14] py-6 text-center text-[10px] font-mono text-[#3A3525] select-none">
    <p>© 2026 Rootword · Trace back to prehistory</p>
  </footer>

</body>
</html>
